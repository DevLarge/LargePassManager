<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.SplitPane?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.Pane?>

<VBox prefHeight="600.0" prefWidth="960.0" style="-fx-background-color: linear-gradient(to bottom, #f6f7fb, #eceff4);" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1">
  <children>
    <SplitPane dividerPositions="0.28, 0.72" prefHeight="-1.0" prefWidth="-1.0" style="-fx-background-color: transparent; -fx-padding: 10 10 6 10;" VBox.vgrow="ALWAYS">
      <items>
        <AnchorPane style="-fx-background-color: #ffffff; -fx-background-radius: 10; -fx-border-color: #d9e0ea; -fx-border-radius: 10;">
          <children>
            <VBox AnchorPane.bottomAnchor="12.0" AnchorPane.leftAnchor="12.0" AnchorPane.rightAnchor="12.0" AnchorPane.topAnchor="12.0" spacing="10.0">
              <children>
                <Label text="Passwords" style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #1f2937;" />
                <ListView fx:id="listPasswords" style="-fx-background-color: #f9fbff; -fx-border-color: #d9e0ea; -fx-border-radius: 8; -fx-background-radius: 8;" VBox.vgrow="ALWAYS" />
                <HBox spacing="8.0">
                  <children>
                    <Button onAction="#openAddEntryWindow" prefHeight="34.0" style="-fx-background-color: #1d4ed8; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8;" text="Add Entry" HBox.hgrow="ALWAYS" maxWidth="1.7976931348623157E308" />
                    <Button onAction="#clickDeleteButton" prefHeight="34.0" style="-fx-background-color: #b91c1c; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8;" text="Delete" HBox.hgrow="ALWAYS" maxWidth="1.7976931348623157E308" />
                  </children>
                </HBox>
              </children>
            </VBox>
          </children>
        </AnchorPane>
        <ScrollPane fitToWidth="true" prefHeight="-1.0" prefWidth="-1.0" style="-fx-background-color: transparent; -fx-border-color: transparent;">
          <content>
            <AnchorPane id="Content" minHeight="-1.0" minWidth="-1.0" prefHeight="545.0" prefWidth="430.0" style="-fx-background-color: #ffffff; -fx-background-radius: 10; -fx-border-color: #d9e0ea; -fx-border-radius: 10;">
              <children>
                <VBox AnchorPane.bottomAnchor="18.0" AnchorPane.leftAnchor="18.0" AnchorPane.rightAnchor="18.0" AnchorPane.topAnchor="18.0" spacing="12.0">
                  <children>
                    <Label text="Entry Details" style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #1f2937;" />
                    <Label text="Service" style="-fx-font-size: 11px; -fx-text-fill: #6b7280;" />
                    <Label fx:id="labelService" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #0f172a;" text="Select an entry" />
                    <Label text="Username" style="-fx-font-size: 11px; -fx-text-fill: #6b7280;" />
                    <Label fx:id="labelUsername" style="-fx-font-size: 14px; -fx-text-fill: #111827;" text="-" />
                    <Label text="Password" style="-fx-font-size: 11px; -fx-text-fill: #6b7280;" />
                    <Label fx:id="labelPassword" style="-fx-font-size: 14px; -fx-text-fill: #111827;" text="-" />
                  </children>
                </VBox>
              </children>
            </AnchorPane>
          </content>
        </ScrollPane>
        <AnchorPane style="-fx-background-color: #ffffff; -fx-background-radius: 10; -fx-border-color: #d9e0ea; -fx-border-radius: 10;">
          <children>
            <VBox AnchorPane.bottomAnchor="14.0" AnchorPane.leftAnchor="14.0" AnchorPane.rightAnchor="14.0" AnchorPane.topAnchor="14.0" spacing="10.0">
              <children>
                <Label text="Quick Tips" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #1f2937;" />
                <Label text="• Click an entry to inspect credentials" style="-fx-text-fill: #4b5563;" wrapText="true" />
                <Label text="• Use Add Entry to create new passwords" style="-fx-text-fill: #4b5563;" wrapText="true" />
                <Label text="• Delete will remove the selected entry" style="-fx-text-fill: #4b5563;" wrapText="true" />
                <Pane VBox.vgrow="ALWAYS" />
                <Label text="Vault loaded" style="-fx-text-fill: #16a34a; -fx-font-weight: bold;" />
              </children>
            </VBox>
          </children>
        </AnchorPane>
      </items>
    </SplitPane>
    <HBox id="HBox" alignment="CENTER_LEFT" spacing="8.0" style="-fx-background-color: #e5e7eb; -fx-padding: 8 12 8 12;" VBox.vgrow="NEVER">
      <children>
        <Label maxHeight="1.7976931348623157E308" maxWidth="-1.0" text="Ready" style="-fx-text-fill: #374151;" HBox.hgrow="ALWAYS" />
        <Pane prefHeight="-1.0" prefWidth="-1.0" HBox.hgrow="ALWAYS" />
        <Label maxWidth="-1.0" text="LargePass Vault" style="-fx-text-fill: #374151;" HBox.hgrow="NEVER" />
      </children>
      <padding>
        <Insets bottom="0.0" left="0.0" right="0.0" top="0.0" />
      </padding>
    </HBox>
  </children>
</VBox>
