<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox prefWidth="400.0" spacing="15.0" style="-fx-padding: 20px;" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1">
    <Label style="-fx-font-size: 18px; -fx-font-weight: bold;" text="Add New Entry" />
    
    <VBox spacing="5.0">
        <Label text="Service Name:" />
        <TextField fx:id="titleField" promptText="e.g., Gmail, GitHub, Netflix" />
    </VBox>
    
    <VBox spacing="5.0">
        <Label text="Username:" />
        <TextField fx:id="usernameField" promptText="Enter username or email" />
    </VBox>
    
    <VBox spacing="5.0">
        <Label text="Password:" />
        <TextField fx:id="passwordField" promptText="Enter password" />
    </VBox>
    
    <HBox spacing="10.0" style="-fx-alignment: center-right;">
        <Button onAction="#saveEntry" style="-fx-padding: 8px 30px;" text="Save" />
        <Button onAction="#cancelEntry" style="-fx-padding: 8px 30px;" text="Cancel" />
    </HBox>
</VBox>
